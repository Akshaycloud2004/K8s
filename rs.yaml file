apiVersion: apps/v1
kind: ReplicaSet
metadata:
    name: rs-name
spec:
   replicas: 3
   selector:
       matchLabels:
               env: app
   template:
       metadata:
           name: tm1
           labels:
              env: app
       spec:
          containers:
              - name: c1
                image: nginx
                ports:
                   - containerPort: 80
